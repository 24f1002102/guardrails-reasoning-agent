# =============================================================================
# Social Media Guardrails Reasoning Agent — Environment Configuration
# Copy this file to .env and fill in values. Never commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Foundry IQ / Azure AI Search policy retrieval
# -----------------------------------------------------------------------------
# "mock" uses the local synthetic policy corpus (src/data/policies.js).
# "live" sends requests to FOUNDRY_IQ_RETRIEVAL_URL using extractive retrieval.
FOUNDRY_IQ_MODE=mock

# Exact retrieval endpoint from your Foundry IQ / Azure AI Search knowledge base.
# The app sends: { query, context, retrievalReasoningEffort: "medium", outputMode: "extractiveData" }
FOUNDRY_IQ_RETRIEVAL_URL=

# Authentication — use one of the following if your endpoint requires it.
FOUNDRY_IQ_API_KEY=
FOUNDRY_IQ_BEARER_TOKEN=

# -----------------------------------------------------------------------------
# Role authentication
# IMPORTANT: Set these to strong random values. If not set, elevated roles
# (admin, reviewer) are never granted — all requests resolve to public-demo.
# Never use default values. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
TRUSTED_ADMIN_SECRET=
TRUSTED_REVIEWER_SECRET=

# -----------------------------------------------------------------------------
# Local server
# -----------------------------------------------------------------------------
PORT=4173

# -----------------------------------------------------------------------------
# Azure OpenAI integration (Governance Deliberation Agent)
# -----------------------------------------------------------------------------
# Leave empty to run in heuristic-fallback mode.
# Endpoint format: https://your-resource-name.openai.azure.com/
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview
